<Window x:Class="ScooterApp.RentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScooterApp"
        mc:Ignorable="d"
        Title="Аренда самоката"
        Height="650"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="SkyBlue"
        FontFamily="Consolas"
        FontSize="22"
        FontWeight="Bold">

    
    <!-- Стили -->
    <Window.Resources>
        <SolidColorBrush x:Key="MainBackgroundBrush" Color="#F4F1E8"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FBF8EF"/>
        <SolidColorBrush x:Key="BorderBrushCustom" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#EEE6D6"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#DDD2BA"/>
        <SolidColorBrush x:Key="StopBrush" Color="#E8C4C4"/>
        <SolidColorBrush x:Key="StopHoverBrush" Color="#DDA9A9"/>
        <SolidColorBrush x:Key="FinishBrush" Color="#D9E8C4"/>
        <SolidColorBrush x:Key="FinishHoverBrush" Color="#BDD7A0"/>

        <Style TargetType="Border" x:Key="PanelBorderStyle">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushCustom}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="TitleStyle">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="ValueStyle">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="54"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushCustom}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D6CAB0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource StopBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource StopHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CF8F8F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FinishButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource FinishBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource FinishHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#A9C98B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14" Background="SkyBlue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Таймер -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <TextBlock Text="Таймер" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="txtTimer" Text="00:00:00" Style="{StaticResource ValueStyle}" FontSize="40"/>
            </StackPanel>
        </Border>

        <!-- Денежная сумма -->
        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <TextBlock Text="Счёт на оплату" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="txtMoney" Text="0.00 ₽" Style="{StaticResource ValueStyle}"/>
            </StackPanel>
        </Border>

        <!-- Информация о самокате -->
        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <TextBlock Text="ID самоката" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="txtScooterId" Text="1" Style="{StaticResource ValueStyle}"/>

                <TextBlock Text="Текущий заряд" Style="{StaticResource LabelStyle}" Margin="0,8,0,6"/>
                <TextBlock x:Name="txtScooterCharge" Text="100%" Style="{StaticResource ValueStyle}"/>
            </StackPanel>
        </Border>

        <!-- Статус поездки -->
        <Border Grid.Row="3" Style="{StaticResource PanelBorderStyle}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="txtRideStatus"
                           Text="Поездка активна"
                           Style="{StaticResource TitleStyle}"/>
                <TextBlock x:Name="txtWarning"
                           Text=""
                           Foreground="DarkRed"
                           FontSize="18"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Блок кнопок (стоп/завершение) -->
        <Grid Grid.Row="4">
            <Button x:Name="btnStopRide"
                    Content="СТОП"
                    Style="{StaticResource StopButtonStyle}"
                    Visibility="Visible"
                    HorizontalAlignment="Left"
                    Width="200"
                    Click="btnStopRide_Click"/>

            <Button x:Name="btnFinish"
                    Content="ЗАВЕРШИТЬ"
                    Style="{StaticResource FinishButtonStyle}"
                    HorizontalAlignment="Right"
                    Width="200"
                    Click="btnFinish_Click"/>
        </Grid>
    </Grid>
</Window>