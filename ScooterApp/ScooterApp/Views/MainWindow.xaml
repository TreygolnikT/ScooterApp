<Window x:Class="ScooterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScooterApp"
        mc:Ignorable="d"
        Title="Вход" Height="600" Width="400" FontFamily="Consolas" FontSize="25" FontWeight="Bold" ResizeMode="NoResize">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0, 0" EndPoint="1, 1">
                <GradientStop Color="GhostWhite"/>
                <GradientStop Color="SkyBlue" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!--Блок текста, приветствующий пользователя-->
        <TextBlock x:Name="txtGreeting" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="35" Grid.Row="0"/>

        <!-- Блок ввода данных -->
        <StackPanel Grid.Row="1" Margin="20" VerticalAlignment="Center">
            <TextBlock Text="Введите логин" FontWeight="Medium"/>
            <TextBox Margin="0 10 0 20" FontWeight="Medium"/>
            <TextBlock Text="Введите пароль" FontWeight="Medium"/>
            <TextBox Margin="0 10 0 0" FontWeight="Medium"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Margin="20" HorizontalAlignment="Center">
            <Button x:Name="btnLogin" Content="Войти" Padding="40 10 40 10" Background="DeepSkyBlue" Cursor="Hand" Click="btnLogin_Click"/>
            <Button x:Name="btnRegister" Content="Зарегистрироваться" Margin="0,10,0,10" Padding="40 10 40 10" Background="DodgerBlue" Cursor="Hand" Click="btnRegister_Click"/>
            <Button x:Name="btnExit" Content="Выйти" Padding="40 10 40 10" Click="btnExit_Click" Background="Tomato" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>